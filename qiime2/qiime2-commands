--i-table deblur/table-deblur-finalv.qza \
--i-phylogeny phylogeny/rooted-tree.qza \
--p-max-depth 10000 \
--m-metadata-file metadata-fruit-2.tsv \
--o-visualization visualizations/alpha-rarefaction_max-10k.qzv

